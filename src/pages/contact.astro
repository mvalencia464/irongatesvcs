---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import TeamGrid from '../components/TeamGrid.astro';
import MapSection from '../components/MapSection.astro';
import { SITE } from '../config/site';

const IG = "https://media.stokeleads.com/irongatesvcs";
const teamMembers = [
  {
    name: SITE.owner.name,
    role: SITE.owner.role,
    image:
      SITE.owner.headshot ||
      `${IG}/modern_bathroom_with_glass_shower_and_tools_on_the_sink_ (1).avif`,
  },
];
---

<BaseLayout
  title={`Contact ${SITE.name} | Free Quote`}
  description={`Contact ${SITE.name} for handyman work, drone services, and real estate support in Tampa, Brandon, and Riverview.`}
>
  <Header />

  <main>
    <section class="section contact-hero">
      <div class="container">
        <span class="section-label">Contact</span>
        <h1>Talk With {SITE.owner.name.split(" ")[0]} at IronGate</h1>
        <p>
          Call for a free, no-obligation quote or send a message with your project details.
          We serve Tampa, Brandon, Riverview, and nearby areas with clear communication from day one.
        </p>
        <div class="contact-hero__actions">
          <a href={`tel:${SITE.phone.replace(/\D/g, '')}`} class="btn btn--primary">Call {SITE.phone}</a>
          <a href={`mailto:${SITE.email}`} class="btn btn--outline">Email {SITE.email}</a>
        </div>
      </div>
    </section>

    <ContactSection />

    <section class="section section--alt">
      <div class="container">
        <TeamGrid members={teamMembers} title="Owner-Operator" />
      </div>
    </section>

    <MapSection />
  </main>

  <Footer />
</BaseLayout>

<style>
  .contact-hero {
    padding-top: 8rem;
  }

  .contact-hero h1 {
    color: var(--text);
    margin-bottom: 0.7rem;
  }

  .contact-hero p {
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.7;
    max-width: 68ch;
  }

  .contact-hero__actions {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
</style>
